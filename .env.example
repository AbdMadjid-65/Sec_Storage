# ============================================================
# PriVault Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# --- Encryption ---
# Salt length in bytes for Argon2id (default: 16)
ARGON2_SALT_LENGTH=16
# Argon2id iterations (default: 3)
ARGON2_ITERATIONS=3
# Argon2id memory in KB (default: 65536 = 64MB)
ARGON2_MEMORY_KB=65536
# Argon2id parallelism (default: 4)
ARGON2_PARALLELISM=4

# --- RevenueCat (optional, for subscription management) ---
REVENUECAT_API_KEY_ANDROID=
REVENUECAT_API_KEY_IOS=

# --- AI Models (optional, for on-device AI) ---
# These are downloaded at runtime; set URLs if self-hosting model files.
# Default: bundled model download URLs in code comments.
AI_MODEL_BASE_URL=
